#!/usr/bin/env sh
# Husky pre-commit hook — run lint-staged over the staged files only.
# POSIX sh for cross-platform parity (Git Bash on Windows, sh on *nix).
# Resolve pnpm whether it is on PATH (normal dev/CI) or only via Corepack.
if command -v pnpm >/dev/null 2>&1; then
  pnpm lint-staged
else
  corepack pnpm lint-staged
fi
