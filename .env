# ClinicOS — base defaults (committed, NON-secret).
# Mode-specific files (.env.development / .env.production / .env.test) and the
# gitignored .env.local override these. NEVER put secrets in any VITE_ var.
VITE_APP_NAME=ClinicOS
VITE_APP_VERSION=0.0.0
VITE_API_BASE_URL=http://localhost:4000/api
VITE_API_TIMEOUT_MS=30000
VITE_DEFAULT_LOCALE=en
VITE_LOG_LEVEL=info
VITE_ENABLE_ANALYTICS=false
