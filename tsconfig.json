/**
 * Solution-style root tsconfig for ClinicOS.
 *
 * Purpose: this file owns NO program of its own — it only references the two
 * real projects so `tsc -b` can build them in dependency order:
 *   - tsconfig.app.json  → the application source under `src/` (DOM + React).
 *   - tsconfig.node.json → the build/config tooling (vite.config, vitest.config, …).
 *
 * Governed by: docs/Coding-Standards.md §2.1 (strict config is non-negotiable),
 * docs/architecture/FolderStructure.md (alias placement), Phase 3 BUILD SPEC.
 */
{
  "files": [],
  "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }]
}
