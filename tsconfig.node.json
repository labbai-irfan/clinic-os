/**
 * Node-side TypeScript project for ClinicOS build & config tooling.
 *
 * Purpose: type-check the files that run in Node during build/test (Vite +
 * Vitest config, Tailwind/PostCSS config, plopfile) — these must NOT inherit
 * the DOM lib or the app's `src` include. Kept strict to match the app.
 *
 * Governed by: docs/Coding-Standards.md §2.1, Phase 3 BUILD SPEC.
 */
{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "noEmit": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    /* Strict safety set — same floor as the app */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "useUnknownInCatchVariables": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "tailwind.config.ts",
    "postcss.config.js",
    "plopfile.js",
    "eslint.config.js"
  ]
}
