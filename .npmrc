# pnpm configuration for ClinicOS.
# auto-install-peers: resolve peer deps automatically (smoother installs across the
#   large React/ESLint/TanStack peer graph).
# strict-peer-dependencies=false: warn (don't fail) on minor peer mismatches so a
#   single transitive peer skew never blocks the whole install. We intentionally do
#   NOT shamefully-hoist — modules stay isolated per the dependency rules.
auto-install-peers=true
strict-peer-dependencies=false
