{
  "name": "clinicos",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "description": "ClinicOS — the digital nervous system of a clinic. Enterprise healthcare SaaS frontend.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode development",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "analyze": "vite build --mode analyze",
    "clean": "rimraf dist node_modules/.vite coverage .turbo",
    "generate": "plop",
    "optimize:svg": "svgo -f src/assets -r --config svgo.config.js",
    "check:assets": "node scripts/check-assets.mjs",
    "ds:registry": "node scripts/ds-registry.mjs",
    "validate:arch": "node scripts/quality/validate-architecture.mjs",
    "check:duplicates": "node scripts/quality/check-duplicates.mjs",
    "check:tokens": "node scripts/quality/check-tokens.mjs",
    "check:i18n": "node scripts/quality/check-i18n.mjs",
    "check:perf": "node scripts/quality/check-perf-budget.mjs",
    "validate:docs": "node scripts/quality/validate-docs.mjs",
    "validate:brain": "node scripts/quality/validate-brain.mjs",
    "quality": "node scripts/quality/quality-gate.mjs",
    "quality:quick": "node scripts/quality/quality-gate.mjs --quick",
    "release:notes": "node scripts/release/generate-release-notes.mjs",
    "phase:complete": "node scripts/phase/complete-phase.mjs",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test && pnpm run validate:arch && pnpm run check:duplicates && pnpm run check:tokens && pnpm run check:i18n && pnpm run ds:registry && pnpm run check:assets && pnpm run validate:docs && pnpm run validate:brain",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.1.0",
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/query-sync-storage-persister": "^5.59.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-devtools": "^5.59.0",
    "@tanstack/react-query-persist-client": "^5.59.0",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "framer-motion": "^11.11.0",
    "i18next": "^23.15.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^2.6.0",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.9",
    "react-error-boundary": "^4.1.2",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.53.0",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^6.27.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.48.0",
    "@storybook/addon-a11y": "^8.3.5",
    "@storybook/addon-essentials": "^8.3.5",
    "@storybook/blocks": "^8.3.5",
    "@storybook/react": "^8.3.5",
    "@storybook/react-vite": "^8.3.5",
    "@storybook/test": "^8.3.5",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^2.1.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-i18next": "^6.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.11.0",
    "husky": "^9.1.6",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "msw": "^2.4.9",
    "plop": "^4.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "rimraf": "^6.0.1",
    "rollup-plugin-visualizer": "^5.12.0",
    "storybook": "^8.3.5",
    "svgo": "^3.3.2",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.9",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.1.3",
    "vitest-axe": "^0.1.0"
  }
}
