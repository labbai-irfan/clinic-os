# ClinicOS — environment template (committed, NON-secret).
#
# Copy to `.env.local` for personal overrides (`.env.local` is gitignored).
# ONLY `VITE_`-prefixed vars reach the client and the bundle is PUBLIC — NEVER
# put secrets here. The schema is validated (fail-fast) in src/shared/config/env.ts.
# See docs/architecture/EnvironmentGuide.md.

# App identity
VITE_APP_NAME=ClinicOS
VITE_APP_ENV=development
VITE_APP_VERSION=0.0.0

# Backend API
VITE_API_BASE_URL=http://localhost:4000/api
VITE_API_TIMEOUT_MS=30000

# Tooling / behavior toggles
VITE_ENABLE_MSW=true
VITE_ENABLE_ANALYTICS=false

# Localization & logging
VITE_DEFAULT_LOCALE=en
VITE_LOG_LEVEL=info

# Optional error monitoring (leave empty to disable)
VITE_SENTRY_DSN=

# Served static assets — empty uses the app base path; set to a CDN origin
# (e.g. https://cdn.clinicos.app) to offload brand/illustration assets.
VITE_ASSET_BASE_URL=
